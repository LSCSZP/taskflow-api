# TaskFlow Environment Configuration
# Copy this file to .env and update values

SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite:///taskflow.db
FLASK_ENV=development
FLASK_DEBUG=1
JWT_EXPIRATION_HOURS=24

